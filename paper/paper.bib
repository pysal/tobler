  @article{laporta2024UrbanScaling,
  title = {Urban {{Scaling Functions}}: {{Emission}}, {{Pollution}} and {{Health
           }}},
  shorttitle = {Urban {{Scaling Functions}}},
  author = {La Porta, Caterina A. M. and Zapperi, Stefano},
  date = {2024-08},
  journaltitle = {Journal of Urban Health},
  shortjournal = {J Urban Health},
  volume = {101},
  number = {4},
  pages = {752--763},
  issn = {1099-3460, 1468-2869},
  doi = {10.1007/s11524-024-00888-2},
  url = {https://link.springer.com/10.1007/s11524-024-00888-2},
  urldate = {2026-04-04},
  abstract = {Abstract Urban scaling is widely used to characterize the
              population dependence of city indicators including greenhouse gas
              emission. Here we analyze the population dependence of CO \$\$\_2\$
              \$ 2 and PM2.5 emissions and concentrations across all European
              cities. Our analysis reveals considerable variations in emissions
              among cities of comparable population size which are not captured
              by conventional urban scaling. We thus characterize these
              fluctuations by multi-parameter scaling functions and multifractal
              spectral analysis. We find that the distribution of emissions and
              population is multifractal while that of air pollution is not,
              leading to non-trivial relations between emission and pollution in
              some large cities. We also analyze the impact of forests in curbing
              emission and the impact of air pollution on health. Our work
              provides a detailed picture of the fluctuations in the scaling of
              urban metabolism in Europe and suggests a general strategy that
              goes beyond conventional urban scaling laws.},
  langid = {english},
}


@article{flowerdew1992DevelopmentsAreal,
  title = {Developments in Areal Interpolation Methods and {{GIS}}},
  author = {Flowerdew, Robin and Green, Mick},
  date = {1992-03-01},
  journaltitle = {The Annals of Regional Science},
  shortjournal = {Ann Reg Sci},
  volume = {26},
  number = {1},
  pages = {67--78},
  issn = {1432-0592},
  doi = {10.1007/BF01581481},
  url = {https://doi.org/10.1007/BF01581481},
  urldate = {2026-04-04},
  abstract = {This paper is a review and extension of the authors' research
              project on areal interpolation. It is concerned with problems
              arising when a region is divided into different sets of zones for
              different purposes, and data available for one set of zones (source
              zones) are needed for a different set (target zones). Standard
              approaches are based on the assumption that source zone data are
              evenly distributed within each zone, but our approach allows
              additional information about the target zones to be taken into
              account so that more accurate target zone estimates can be derived.
              The method used is based on the EM algorithm. Most of the work
              reported so far (e.g. Flowerdew and Green 1989) has been concerned
              with count data whose distribution can be modelled using a Poisson
              assumption. Such data are frequently encountered in censuses and
              surveys. Other types of data are more appropriately regarded as
              having continuous distributions. This paper is primarily concerned
              with areal interpolation of normally distributed data. A method is
              developed suitable for such data and is applied to house price data
              for Preston, Lancashire, starting with mean house prices in 1990
              for local government wards and estimating mean house prices for
              postcode sectors.},
  langid = {english},
  keywords = {Count Data,Environmental Economic,House Price,Local Government,
              Standard Approach},
}
